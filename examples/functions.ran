#!/usr/bin/env ran
# Functions

fn greet(name: str) {
    echo "Hello, $name!"
}

fn add(a: int, b: int) -> int {
    return a + b
}

fn factorial(n: int) -> int {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

fn main() {
    greet("World")
    greet("Ran")

    let result = add(10, 20)
    echo "10 + 20 = $result"

    let fact = factorial(5)
    echo "5! = $fact"
}
